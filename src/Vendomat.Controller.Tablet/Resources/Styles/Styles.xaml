<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource MilkCream}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MutedInk}" />
        <Setter Property="BackgroundColor" Value="{StaticResource MilkWhite}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource MilkWhite}" />
        <Setter Property="BackgroundColor" Value="{StaticResource FarmGreen}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource MilkWhite}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 24" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource AccentAmber}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource FarmGreen}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource MilkCream}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Ink}" />
    </Style>

</ResourceDictionary>
